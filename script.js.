// Логика для воды
let water = 0.0;
function changeValue(type, amount) {
    if (type === 'water') {
        water = Math.round((water + amount) * 10) / 10;
        document.getElementById('water-val').innerText = water.toFixed(1);
    }
}

// Автоматическая дата (Израильское время)
const days = ['Воскресенье', 'Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота'];
const months = ['марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря', 'января', 'февраля'];

const now = new Date();
// Подставляем данные в HTML
document.getElementById('current-day').innerText = days[now.getDay()];
document.getElementById('current-date').innerText = now.getDate() + ' ' + months[now.getMonth() - 2] + ' ' + now.getFullYear() + ' г.';
