body {
    background-color: #0f172a;
    color: white;
    font-family: -apple-system, system-ui, sans-serif;
    display: flex;
    justify-content: center;
    margin: 0;
    min-height: 100vh;
}

.app-container {
    width: 100%;
    max-width: 400px;
    padding: 20px;
}

header h1 { font-size: 32px; margin-bottom: 0; }
header p { color: #94a3b8; margin-top: 5px; font-size: 14px; }

.grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin: 30px 0;
}

.card {
    background: #1e293b;
    padding: 20px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    border-left: 6px solid;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
}

/* Цвета как на твоём скрине */
.blue { border-color: #3b82f6; }   /* Брусья */
.orange { border-color: #f97316; } /* Турник */
.yellow { border-color: #eab308; } /* Дорожка */
.green { border-color: #22c55e; }  /* Приседы */

.val { font-size: 36px; font-weight: bold; margin-bottom: 5px; }
.lab { font-size: 12px; color: #94a3b8; font-weight: 600; letter-spacing: 0.5px; }

.actions {
    background: #1e293b;
    padding: 20px;
    border-radius: 20px;
    margin-top: 20px;
}

.btn-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

button {
    background: #334155;
    color: #3b82f6;
    border: none;
    padding: 10px 15px;
    border-radius: 10px;
    font-weight: bold;
    cursor: pointer;
}

button:active { transform: scale(0.95); }
