<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>GYM OS</title>
    <style>
        body { background: #0f172a; color: white; font-family: sans-serif; display: flex; justify-content: center; padding: 20px; margin: 0; }
        .app { width: 100%; max-width: 400px; }
        .status-ready { color: #22c55e; font-weight: bold; margin-bottom: 20px; text-align: center; border: 1px solid #22c55e; padding: 10px; border-radius: 10px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .card { background: #1e293b; padding: 20px; border-radius: 20px; border-left: 6px solid #3b82f6; }
        .val { font-size: 30px; font-weight: bold; display: block; }
        .label { font-size: 12px; color: #94a3b8; }
        .water { margin-top: 20px; background: #1e293b; padding: 20px; border-radius: 20px; display: flex; justify-content: space-between; align-items: center; }
        button { background: #334155; color: #3b82f6; border: none; padding: 10px 15px; border-radius: 10px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="app">
        <div class="status-ready">СИСТЕМА ГОТОВА К ВОСКРЕСЕНЬЮ</div>
        <h1 id="day" style="margin: 0 0 20px 0;">Загрузка...</h1>
        
        <div class="grid">
            <div class="card"><span class="val">0</span><span class="label">БРУСЬЯ</span></div>
            <div class="card" style="border-color: #f97316;"><span class="val">0</span><span class="label">ТУРНИК</span></div>
        </div>

        <div class="water">
            <span>ВОДА: <strong id="w">0.0</strong>л</span>
            <button onclick="document.getElementById('w').innerText=(parseFloat(document.getElementById('w').innerText)+0.1).toFixed(1)">+0.1</button>
        </div>
    </div>
    <script>
        const days = ['Воскресенье', 'Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота'];
        document.getElementById('day').innerText = days[new Date().getDay()];
    </script>
</body>
</html>
