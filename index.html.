<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Home Gym OS</title>
    <style>
        body { background-color: #0f172a; color: white; font-family: -apple-system, sans-serif; display: flex; justify-content: center; margin: 0; padding: 20px; }
        .container { width: 100%; max-width: 400px; }
        header { margin-bottom: 25px; }
        h1 { font-size: 32px; margin: 0; color: #3b82f6; }
        .date { color: #94a3b8; font-size: 14px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .card { background: #1e293b; padding: 20px; border-radius: 20px; border-left: 6px solid; display: flex; flex-direction: column; }
        .blue { border-color: #3b82f6; } .orange { border-color: #f97316; }
        .yellow { border-color: #eab308; } .green { border-color: #22c55e; }
        .val { font-size: 32px; font-weight: bold; }
        .lab { font-size: 11px; color: #94a3b8; font-weight: bold; letter-spacing: 0.5px; }
        .actions { background: #1e293b; padding: 15px; border-radius: 20px; margin-top: 25px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #334155; }
        button { background: #334155; color: #3b82f6; border: none; padding: 12px 18px; border-radius: 12px; font-weight: bold; cursor: pointer; }
        button:active { background: #475569; transform: scale(0.95); }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1 id="day-name">Воскресенье</h1>
            <div class="date" id="full-date">7 марта 2026</div>
        </header>

        <div class="grid">
            <div class="card blue"><span class="val">0</span><span class="lab">БРУСЬЯ</span></div>
            <div class="card orange"><span class="val">0</span><span class="lab">ТУРНИК</span></div>
            <div class="card yellow"><span class="val">0.0</span><span class="lab">ДОРОЖКА</span></div>
            <div class="card green"><span class="val">0</span><span class="lab">ПРИСЕДЫ</span></div>
        </div>

        <div class="actions">
            <span>💧 ВОДА: <strong id="w-val">0.0</strong>л</span>
            <div>
                <button onclick="addW(0.1)">+0.1</button>
                <button onclick="addW(0.3)">+0.3</button>
            </div>
        </div>
    </div>

    <script>
        let w = 0.0;
        function addW(v) {
            w = Math.round((w + v) * 10) / 10;
            document.getElementById('w-val').innerText = w.toFixed(1);
        }

        const days = ['Воскресенье', 'Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота'];
        const months = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];
        const n = new Date();
        document.getElementById('day-name').innerText = days[n.getDay()];
        document.getElementById('full-date').innerText = n.getDate() + ' ' + months[n.getMonth()] + ' ' + n.getFullYear() + ' г.';
    </script>
</body>
</html>
